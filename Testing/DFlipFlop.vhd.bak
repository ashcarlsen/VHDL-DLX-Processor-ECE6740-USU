library ieee;
use ieee.std_logic_1164.all;

entity DFlipFlop is
	port (
		MAX10_CLK1_50 : in std_logic;
		KEY[0] : in std_logic;
		SW[0] : in std_logic;
		LEDR[0] : out std_logic
	);
end DFlipFlop

architecture rtl of DFlipFlop is
	component myDFlipFlop is
		port (
			clk : in std_logic;
			rst_l : in std_logic;
			d : in std_logic;
			q : out std_logic
		);
	begin
	end
end rtl